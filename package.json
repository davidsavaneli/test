{
  "name": "sava-test",
  "version": "0.0.5",
  "description": "Techzy UI — reusable React component library for admin panels.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/entries/components.d.ts",
        "default": "./dist/entries/components.js"
      },
      "require": {
        "types": "./dist/entries/components.d.cts",
        "default": "./dist/entries/components.cjs"
      }
    },
    "./components/*": {
      "import": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.js"
      },
      "require": {
        "types": "./dist/components/*/index.d.cts",
        "default": "./dist/components/*/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/entries/hooks.d.ts",
        "default": "./dist/entries/hooks.js"
      },
      "require": {
        "types": "./dist/entries/hooks.d.cts",
        "default": "./dist/entries/hooks.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/entries/theme.d.ts",
        "default": "./dist/entries/theme.js"
      },
      "require": {
        "types": "./dist/entries/theme.d.cts",
        "default": "./dist/entries/theme.cjs"
      }
    },
    "./icons": {
      "import": {
        "types": "./dist/entries/icons.d.ts",
        "default": "./dist/entries/icons.js"
      },
      "require": {
        "types": "./dist/entries/icons.d.cts",
        "default": "./dist/entries/icons.cjs"
      }
    },
    "./helpers": {
      "import": {
        "types": "./dist/entries/helpers.d.ts",
        "default": "./dist/entries/helpers.js"
      },
      "require": {
        "types": "./dist/entries/helpers.d.cts",
        "default": "./dist/entries/helpers.cjs"
      }
    },
    "./css/reset.css": "./dist/reset.css",
    "./css/styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && node scripts/post-build.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "dev": "vite build --watch",
    "playground": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:pkg": "publint",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-router": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-router": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.170.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "publint": "^0.3.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.8",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  }
}
